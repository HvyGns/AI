        // Initialize Dynamic Actions
        addObjectiveBtn.addEventListener('click', () => addObjectiveRow());
        addPretestBtn.addEventListener('click', () => addPretestRow());

        // Preset Load logic
        presetSelect.addEventListener('change', (e) => {
            const presetKey = e.target.value;
            if (!presetKey) return;
            const preset = PRESETS[presetKey];
            
            // Populate basic fields
            lessonTitleInput.value = preset.title;
            lessonSubjectSelect.value = preset.subject;
            studentLevelSelect.value = preset.level;
