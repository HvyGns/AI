        });

        // Initialize with default template to make the app interactive on first load
        function loadDefaultSetup() {
            presetSelect.value = "ics";
            presetSelect.dispatchEvent(new Event('change'));
            compilePrompt();
        }

        // Core prompt structuring compiling logic
        function compilePrompt() {
            const title = lessonTitleInput.value.trim() || "Advanced Industrial Systems Intrusion Engineering";
            const subject = lessonSubjectSelect.value;
            const level = studentLevelSelect.value;
            const terms = keyTermsTextarea.value.trim();
            const role = promptRoleSelect.value;
            const format = promptFormatSelect.value;

            // Extract objectives from DOM fields
            const objectives = [];
            const objInputs = objectivesContainer.querySelectorAll('input');
            objInputs.forEach(inp => {
                if(inp.value.trim()) {
                    objectives.push(inp.value.trim());
                }
            });

            // Extract pretest items
            const pretests = [];
            const prInputs = pretestsContainer.querySelectorAll('input');
            prInputs.forEach(inp => {
                if(inp.value.trim()) {
                    pretests.push(inp.value.trim());
                }
            });

            // Construct Prompt Template using formal AI System Instructions
            let promptText = `# SYSTEM ASSIGNMENT ROLE
You are acting as a world-class ${role} specializing in ${subject}. 
Your target educational audience is strictly at the "${level}" tier. 
Adopt a highly analytical, academically rigorous, and direct communication tone.

# COURSE DETAILS
- Lesson Title: ${title}
- Academic Discipline: ${subject}
- Targeted Competence Level: ${level}

# CORE LEARNING OBJECTIVES
By the end of this exercise, students must demonstrate critical proficiency in the following dimensions:\n`;

            if (objectives.length > 0) {
                objectives.forEach((obj, idx) => {
                    promptText += `  ${idx + 1}. [Bloom's Target] ${obj}\n`;
                });
            } else {
                promptText += `  - Identify structural vulnerabilities unique to the subject domain.\n  - Apply hardening configurations matching NIST/OWASP guidance.\n`;
            }

            promptText += `\n# REQUIRED KEY TERMINOLOGY
The compiled output must explicitly introduce, test, or scaffold around these technical concepts:\n`;
            if (terms) {
                terms.split(',').forEach(term => {
                    promptText += `  - ${term.trim()}\n`;
                });
            } else {
                promptText += `  - SCADA, Modbus, Adversarial Attacks, Defense Distillation\n`;
            }

            promptText += `\n# PRE-ASSESSMENT (DIAGNOSTIC TEST)
Before engaging with the primary lab material, evaluate or assume students can answer these exact questions:\n`;
            if (pretests.length > 0) {
                pretests.forEach((test, idx) => {
                    promptText += `  Question ${idx + 1}: ${test}\n`;
                });
            } else {
                promptText += `  Question 1: What is the fundamental protocol format or vulnerability mechanism defining this field?\n`;
            }

            promptText += `\n# SPECIFIC INSTRUCTIONAL DELIVERABLE
Your main task is to construct a complete, self-contained "${format}".
Ensure that you:
1. Embed multiple layers of technical depth suitable for ${level}.
2. Provide precise, actionable syntax, diagnostic PCAP references, log traces, or structural code architectures where appropriate.
3. Incorporate complex failure modes (e.g., unexpected network noise, adversarial evasion, or multi-stage pivot paths) to push critical thinking.
4. Integrate a marking checklist or evaluation metric mapped directly to the core Learning Objectives.

Begin constructing the educational material below:`;

            promptOutputTextarea.value = promptText;
        }

        // Action Listener to trigger dynamic rendering
        generatePromptBtn.addEventListener('click', () => {
            compilePrompt();
            showToast("Prompt template generated & updated", "success");
        });

        // Copy Clipboard logic with standard document.execCommand fallback
        function handleCopy(textareaElement) {
            textareaElement.select();
            textareaElement.setSelectionRange(0, 99999); // Mobile compatibility
            try {
                document.execCommand('copy');
                return true;
            } catch (err) {
                console.error('Copy fallback failed', err);
                return false;
            }
        }

        copyPromptBtn.addEventListener('click', () => {
            const success = handleCopy(promptOutputTextarea);
            if (success) {
                toastFeedback.classList.remove('opacity-0');
                toastFeedback.classList.add('opacity-100');
                setTimeout(() => {
                    toastFeedback.classList.remove('opacity-100');
                    toastFeedback.classList.add('opacity-0');
                }, 2000);
                showToast("Copied prompt template!", "success");
            }
        });

        copyExecBtn.addEventListener('click', () => {
            // Select the text internally
            const range = document.createRange();
            range.selectNode(executionResultText);
            window.getSelection().removeAllRanges();
            window.getSelection().addRange(range);
            try {
                document.execCommand('copy');
                showToast("Copied generation content!", "success");
            } catch (e) {
                showToast("Failed to copy", "error");
            }
            window.getSelection().removeAllRanges();
        });

        // Non-intrusive Accessibility Toast Engine
        function showToast(message, type = "success") {
            const toast = document.getElementById('globalToast');
            const msgEl = document.getElementById('toastMessage');
            const iconContainer = document.getElementById('toastIconContainer');
            
            msgEl.textContent = message;
            
            if (type === 'success') {
                iconContainer.className = "p-1 rounded-lg bg-cyber-600";
                iconContainer.innerHTML = `<i data-lucide="check" class="w-4 h-4 text-white"></i>`;
            } else if (type === 'error') {
                iconContainer.className = "p-1 rounded-lg bg-rose-600";
                iconContainer.innerHTML = `<i data-lucide="alert-triangle" class="w-4 h-4 text-white"></i>`;
            } else {
                iconContainer.className = "p-1 rounded-lg bg-brand-600";
                iconContainer.innerHTML = `<i data-lucide="info" class="w-4 h-4 text-white"></i>`;
            }
            
            lucide.createIcons();
            
            // Slide in animation
            toast.className = "fixed bottom-5 right-5 z-50 transform translate-y-0 opacity-100 transition-all duration-300 bg-slate-900 text-white border border-slate-800 px-4 py-3 rounded-xl shadow-2xl flex items-center gap-3";
            
            setTimeout(() => {
                toast.className = "fixed bottom-5 right-5 z-50 transform translate-y-10 opacity-0 transition-all duration-300 bg-slate-900 text-white border border-slate-800 px-4 py-3 rounded-xl shadow-2xl flex items-center gap-3 pointer-events-none";
            }, 3000);
        }

        // ==========================================
        // Gemini API Execution with Exponential Backoff
        // ==========================================
        async function runGeminiGeneration() {
            // Re-compile dynamic state to verify fresh user settings
            compilePrompt();
            
            const promptContent = promptOutputTextarea.value;
            if (!promptContent) {
                showToast("Please compile a prompt template first", "error");
                return;
            }

            // Switch UI views to Execution Panel
            switchTab('execution');
            executionPlaceholder.classList.add('hidden');
            executionLoading.classList.remove('hidden');
            executionResultText.classList.add('hidden');
            executionResultText.innerHTML = "";

            const targetUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;

            const payload = {
                contents: [{
                    parts: [{
                        text: promptContent
                    }]
                }],
                systemInstruction: {
                    parts: [{
                        text: "You are an advanced educator assisting a computer science professor. Generate the requested educational syllabus, guide, rubric, or assignment text in full markdown layout. Do not summarize or use generic placeholders."
                    }]
                }
            };

            // Call API with Exponential Backoff Retries as instructed
            const maxRetries = 5;
            let attempt = 0;
            let success = false;
            let responseData = null;

            while (attempt < maxRetries && !success) {
                try {
                    const response = await fetch(targetUrl, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify(payload)
                    });

                    if (response.ok) {
                        responseData = await response.json();
                        success = true;
                    } else {
                        throw new Error(`API error code: ${response.status}`);
                    }
                } catch (error) {
                    attempt++;
                    if (attempt >= maxRetries) {
                        executionLoading.classList.add('hidden');
                        executionPlaceholder.classList.remove('hidden');
                        showToast("API generation connection failed after 5 retries.", "error");
                        executionConsole.innerHTML = `
                            <div class="p-4 border border-rose-900 bg-rose-950/20 text-rose-400 rounded-lg">
                                <h4 class="font-bold">Execution Failure</h4>
                                <p class="text-xs mt-1">Unable to contact the AI model. Check your custom environment settings or make sure the network allows endpoints to generativelanguage.googleapis.com.</p>
                                <button onclick="runGeminiGeneration()" class="mt-3 px-3 py-1.5 bg-rose-800 hover:bg-rose-700 text-white rounded text-xs font-bold transition">
                                    Retry Connection
                                </button>
                            </div>
                        `;
                        return;
                    }
                    // Wait for exponential backoff: 1s, 2s, 4s, 8s, 16s
                    const delay = Math.pow(2, attempt - 1) * 1000;
                    await new Promise(resolve => setTimeout(resolve, delay));
                }
            }

            if (success && responseData) {
                const textOutput = responseData.candidates?.[0]?.content?.parts?.[0]?.text;
                if (textOutput) {
                    executionLoading.classList.add('hidden');
                    executionResultText.classList.remove('hidden');
                    
                    // Display the resulting content
                    executionResultText.innerHTML = formatMarkdown(textOutput);
                    showToast("Coursework successfully created!", "success");
                } else {
                    executionLoading.classList.add('hidden');
                    executionPlaceholder.classList.remove('hidden');
                    showToast("No content was returned by the AI engine.", "error");
                }
            }
        }

        // Simple and robust parser to display markdown clean and readable
        function formatMarkdown(text) {
            let html = text
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;");

            // Convert Code blocks
            html = html.replace(/```(.*?)\n([\s\S]*?)```/g, function(match, lang, code) {
                return `<pre class="bg-slate-900 border border-slate-800 text-cyan-400 p-4 rounded-lg my-3 font-mono text-xs overflow-x-auto whitespace-pre"><code>${code.trim()}</code></pre>`;
            });

            // Headers
            html = html.replace(/^### (.*$)/gim, '<h4 class="text-md font-bold mt-4 text-brand-400">$1</h4>');
            html = html.replace(/^## (.*$)/gim, '<h3 class="text-lg font-bold mt-5 mb-2 text-brand-300 border-b border-slate-800 pb-1">$1</h3>');
            html = html.replace(/^# (.*$)/gim, '<h2 class="text-xl font-black mt-6 mb-3 text-white">$1</h2>');

            // Bold
            html = html.replace(/\*\*(.*?)\*\*/g, '<strong class="font-bold text-white">$1</strong>');

            // Bullet points
            html = html.replace(/^\s*-\s*(.*$)/gim, '<li class="ml-4 list-disc text-slate-300 mt-1">$1</li>');

            return html;
        }

        // Event handler connection for Prompt Execution
        executeAIBtn.addEventListener('click', runGeminiGeneration);

        // Run default state load on load event
        window.onload = function() {
            loadDefaultSetup();
        };
    </script>
