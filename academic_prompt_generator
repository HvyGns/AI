            objectivesContainer.innerHTML = "";
            objectiveCount = 0;
            preset.objectives.forEach(obj => addObjectiveRow(obj));

            // Purge and reload Pre-test inputs
            pretestsContainer.innerHTML = "";
            pretestCount = 0;
            preset.pretests.forEach(test => addPretestRow(test));

