        tabTemplateBtn.addEventListener('click', () => switchTab('template'));
        tabExecutionBtn.addEventListener('click', () => switchTab('execution'));

        // Dynamic Line Builders with appropriate labels for ADA Compliance
        function addObjectiveRow(value = "") {
            objectiveCount++;
