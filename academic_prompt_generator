                       placeholder="e.g. Map attack surface vectors in modbus frame architectures..."
                       aria-label="Learning objective ${objectiveCount}">
                <button type="button" onclick="removeObjectiveRow(${objectiveCount})" class="text-rose-500 hover:text-rose-700 p-1.5 focus:outline-none focus:ring-2 focus:ring-rose-500 rounded" aria-label="Delete objective line ${objectiveCount}">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
